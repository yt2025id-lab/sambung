{
  "name": "sambung",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "db:migrate": "pnpm --filter @sambung/database db:migrate",
    "db:seed": "pnpm --filter @sambung/database db:seed",
    "db:studio": "pnpm --filter @sambung/database db:studio",
    "contracts:build": "stellar contract build --manifest-path contracts/payment-gateway/Cargo.toml",
    "contracts:deploy:testnet": "bash scripts/deploy-contracts.sh testnet",
    "contracts:deploy:mainnet": "bash scripts/deploy-contracts.sh mainnet",
    "deploy:staging": "turbo deploy --filter=@sambung/api --filter=@sambung/web"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.10.1"
    }
  },
  "devDependencies": {
    "prettier": "^3.3.0",
    "turbo": "^2.0.0",
    "typescript": "^5.6.0",
    "vercel": "^56.2.0"
  }
}
